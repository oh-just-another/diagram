{
  "name": "@oh-just-another/react-ui",
  "version": "0.58.0",
  "description": "React components and hooks over the diagram editor — DiagramCanvas, Toolbar, Palette, PropertyPanel.",
  "license": "MIT",
  "author": "Rustam Garifulin <rustam@n69.in>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oh-just-another/diagram.git",
    "directory": "packages/react-ui"
  },
  "homepage": "https://github.com/oh-just-another/diagram#readme",
  "bugs": "https://github.com/oh-just-another/diagram/issues",
  "keywords": [
    "diagram",
    "canvas",
    "svg",
    "editor",
    "graph",
    "drawing"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oh-just-another/events": "workspace:*",
    "@oh-just-another/math": "workspace:*",
    "@oh-just-another/renderer-canvas": "workspace:*",
    "@oh-just-another/renderer-core": "workspace:*",
    "@oh-just-another/renderer-svg": "workspace:*",
    "@oh-just-another/scene": "workspace:*",
    "@oh-just-another/state": "workspace:*",
    "@oh-just-another/templates": "workspace:*",
    "@oh-just-another/tokens": "workspace:*",
    "@oh-just-another/types": "workspace:*",
    "@oh-just-another/versioning": "workspace:*",
    "@floating-ui/dom": "1.7.6",
    "lucide-react": "1.16.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "axe-core": "4.11.4",
    "jsdom": "25.0.1",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  }
}
