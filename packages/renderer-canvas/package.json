{
  "name": "@oh-just-another/renderer-canvas",
  "version": "0.51.78",
  "description": "renderer-canvas package",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./render-worker": {
      "types": "./dist/render-worker.d.ts",
      "import": "./dist/render-worker.js"
    },
    "./dist/render-worker.js": "./dist/render-worker.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oh-just-another/curve-mesh": "workspace:*",
    "@oh-just-another/glyph-atlas": "workspace:*",
    "@oh-just-another/math": "workspace:*",
    "@oh-just-another/renderer-core": "workspace:*",
    "@oh-just-another/renderer-workers": "workspace:*",
    "@oh-just-another/scene": "workspace:*",
    "@oh-just-another/types": "workspace:*",
    "earcut": "^3.0.2"
  },
  "devDependencies": {
    "@types/earcut": "^3.0.0"
  }
}