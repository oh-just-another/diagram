{
  "name": "@oh-just-another/diagram",
  "version": "0.0.0",
  "description": "Drop-in diagram editor component. Auto-detects browser capabilities (renderer / WASM / workers) and exposes a single <Diagram> React component with plugin / slot / theme props.",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "vite",
    "dev:fresh": "vite --force",
    "build": "vite build",
    "preview": "vite preview",
    "clean:cache": "rm -rf node_modules/.vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@oh-just-another/collab": "workspace:*",
    "@oh-just-another/history": "workspace:*",
    "@oh-just-another/network": "workspace:*",
    "@oh-just-another/raster-wasm": "workspace:*",
    "@oh-just-another/react-ui": "workspace:*",
    "@oh-just-another/renderer-canvas": "workspace:*",
    "@oh-just-another/renderer-core": "workspace:*",
    "@oh-just-another/renderer-svg": "workspace:*",
    "@oh-just-another/scene": "workspace:*",
    "@oh-just-another/serialization": "workspace:*",
    "@oh-just-another/state": "workspace:*",
    "@oh-just-another/templates": "workspace:*",
    "@oh-just-another/templates-jsx": "workspace:*",
    "@oh-just-another/text-wasm": "workspace:*",
    "@oh-just-another/types": "workspace:*",
    "@oh-just-another/versioning": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7"
  }
}
