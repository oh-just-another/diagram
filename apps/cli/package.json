{
  "name": "@oh-just-another/cli",
  "version": "0.34.2",
  "description": "Command-line interface for headless diagram rendering.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "diagram": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "private": true,
  "dependencies": {
    "@oh-just-another/headless": "workspace:*",
    "@oh-just-another/exporter": "workspace:*",
    "@oh-just-another/importers": "workspace:*",
    "@oh-just-another/serialization": "workspace:*"
  }
}