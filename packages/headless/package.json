{
  "name": "@oh-just-another/headless",
  "version": "0.55.38",
  "description": "Headless rendering engine \u2014 turn a Scene into SVG / PNG in Node.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "lint": "eslint src tests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oh-just-another/types": "workspace:*",
    "@oh-just-another/scene": "workspace:*",
    "@oh-just-another/serialization": "workspace:*",
    "@oh-just-another/renderer-core": "workspace:*",
    "@oh-just-another/renderer-svg": "workspace:*",
    "@oh-just-another/tokens": "workspace:*"
  },
  "peerDependencies": {
    "@resvg/resvg-js": "^2.6.0"
  },
  "peerDependenciesMeta": {
    "@resvg/resvg-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.0",
    "tinybench": "^3.0.0"
  }
}