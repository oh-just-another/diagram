# Copy to `.env.local` to override locally (gitignored).

# WebSocket relay endpoint for cross-machine collab.
# Default = empty = same-origin `/relay`, proxied by Vite to the
# bundled `apps/relay` (or `diagram-collab` repo) on `ws://localhost:1234`.
# Override to point at a foreign relay:
#   VITE_RELAY_URL=ws://192.168.1.5:1234
#   VITE_RELAY_URL=wss://relay.example.com
VITE_RELAY_URL=
