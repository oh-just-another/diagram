{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "tests", "**/*.test.ts", "**/*.test.tsx"],
  "references": [
    { "path": "../editor/tsconfig.build.json" },
    { "path": "../react-ui/tsconfig.build.json" },
    { "path": "../scene/tsconfig.build.json" }
  ]
}
