{
  "name": "@oh-just-another/svelte",
  "version": "0.0.0",
  "description": "Svelte 5 wrapper for the diagram editor — a thin <OhDiagram> component over the <oh-diagram> custom element.",
  "license": "MIT",
  "author": "Rustam Garifulin <rustam@n69.in>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oh-just-another/diagram.git",
    "directory": "packages/svelte"
  },
  "homepage": "https://github.com/oh-just-another/diagram#readme",
  "bugs": "https://github.com/oh-just-another/diagram/issues",
  "keywords": [
    "diagram",
    "canvas",
    "editor",
    "svelte",
    "svelte5"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "svelte": "./src/OhDiagram.svelte",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./src/OhDiagram.svelte"
    },
    "./OhDiagram.svelte": {
      "svelte": "./src/OhDiagram.svelte"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "@oh-just-another/element": "workspace:*",
    "@oh-just-another/scene": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "svelte": "5.56.4",
    "vite": "6.4.3"
  }
}
