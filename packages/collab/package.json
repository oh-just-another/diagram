{
  "name": "@oh-just-another/collab",
  "version": "0.23.10",
  "description": "Real-time collaboration: Yjs binding for scenes + awareness for presence.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oh-just-another/types": "workspace:*",
    "@oh-just-another/scene": "workspace:*",
    "@oh-just-another/state": "workspace:*",
    "@oh-just-another/serialization": "workspace:*",
    "@oh-just-another/network": "workspace:*",
    "yjs": "^13.6.20",
    "y-protocols": "^1.0.6"
  }
}