{
  "name": "@oh-just-another/headless",
  "version": "0.58.0",
  "description": "Headless rendering engine — turn a Scene into SVG / PNG in Node.",
  "license": "MIT",
  "author": "Rustam Garifulin <rustam@n69.in>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oh-just-another/diagram.git",
    "directory": "packages/headless"
  },
  "homepage": "https://github.com/oh-just-another/diagram#readme",
  "bugs": "https://github.com/oh-just-another/diagram/issues",
  "keywords": [
    "diagram",
    "canvas",
    "svg",
    "editor",
    "graph",
    "drawing"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "lint": "eslint src tests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oh-just-another/types": "workspace:*",
    "@oh-just-another/scene": "workspace:*",
    "@oh-just-another/serialization": "workspace:*",
    "@oh-just-another/renderer-svg": "workspace:*",
    "@oh-just-another/tokens": "workspace:*"
  },
  "peerDependencies": {
    "@resvg/resvg-js": "^2.6.0"
  },
  "peerDependenciesMeta": {
    "@resvg/resvg-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@resvg/resvg-js": "2.6.2",
    "tinybench": "3.1.1"
  }
}
