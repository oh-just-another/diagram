{
  "name": "@oh-just-another/demo",
  "version": "0.26.31",
  "description": "Demo application \u2014 full-featured React editor built on top of @oh-just-another/react-ui.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:canvas2d": "VITE_RENDERER=canvas2d vite",
    "dev:webgl2": "VITE_RENDERER=webgl2 vite",
    "dev:offscreen": "VITE_RENDERER=offscreen vite",
    "dev:fresh": "vite --force",
    "build": "vite build",
    "build:canvas2d": "VITE_RENDERER=canvas2d vite build",
    "build:webgl2": "VITE_RENDERER=webgl2 vite build",
    "build:offscreen": "VITE_RENDERER=offscreen vite build",
    "preview": "vite preview",
    "clean:cache": "rm -rf node_modules/.vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@oh-just-another/types": "workspace:*",
    "@oh-just-another/scene": "workspace:*",
    "@oh-just-another/state": "workspace:*",
    "@oh-just-another/history": "workspace:*",
    "@oh-just-another/templates": "workspace:*",
    "@oh-just-another/templates-jsx": "workspace:*",
    "@oh-just-another/renderer-canvas": "workspace:*",
    "@oh-just-another/renderer-svg": "workspace:*",
    "@oh-just-another/serialization": "workspace:*",
    "@oh-just-another/network": "workspace:*",
    "@oh-just-another/collab": "workspace:*",
    "@oh-just-another/versioning": "workspace:*",
    "@oh-just-another/react-ui": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7"
  }
}