{
  "name": "@oh-just-another/diagram",
  "version": "0.1.0",
  "description": "Framework-neutral custom element (<oja-diagram>) wrapping the diagram editor — drop into any framework or plain HTML.",
  "license": "MIT",
  "author": "Rustam Garifulin <rustam@n69.in>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oh-just-another/diagram.git",
    "directory": "packages/diagram"
  },
  "homepage": "https://github.com/oh-just-another/diagram#readme",
  "bugs": "https://github.com/oh-just-another/diagram/issues",
  "keywords": [
    "diagram",
    "canvas",
    "editor",
    "web-component",
    "custom-element"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./global": "./dist/oja-diagram.global.js"
  },
  "files": [
    "dist",
    "wasm",
    "fonts",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "./dist/index.js",
    "./dist/oja-diagram.global.js"
  ],
  "scripts": {
    "gen:styles": "node scripts/gen-styles.mjs",
    "dev": "vite",
    "build": "pnpm gen:styles && tsc -b tsconfig.build.json && pnpm build:cdn",
    "build:cdn": "node scripts/build-cdn.mjs",
    "typecheck": "pnpm gen:styles && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "clean": "rm -rf dist wasm fonts *.tsbuildinfo src/styles.generated.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oh-just-another/editor": "workspace:*",
    "@oh-just-another/react-ui": "workspace:*",
    "@oh-just-another/scene": "workspace:*",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "esbuild": "0.25.12",
    "jsdom": "25.0.1",
    "vite": "6.4.3"
  }
}
