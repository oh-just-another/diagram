{
  "name": "@oh-just-another/exporter",
  "version": "0.53.3",
  "description": "Hi-res image and PDF export for @oh-just-another/scene documents.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oh-just-another/types": "workspace:*",
    "@oh-just-another/scene": "workspace:*",
    "@oh-just-another/serialization": "workspace:*",
    "@oh-just-another/headless": "workspace:*",
    "@oh-just-another/renderer-svg": "workspace:*"
  },
  "peerDependencies": {
    "@resvg/resvg-js": "^2.6.0",
    "pdfkit": "^0.15.0",
    "svg-to-pdfkit": "^0.1.8"
  },
  "peerDependenciesMeta": {
    "@resvg/resvg-js": {
      "optional": true
    },
    "pdfkit": {
      "optional": true
    },
    "svg-to-pdfkit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.0",
    "pdfkit": "^0.15.0",
    "svg-to-pdfkit": "^0.1.8",
    "@types/pdfkit": "^0.13.0",
    "@types/svg-to-pdfkit": "^0.1.4"
  }
}