{
  "name": "@oh-just-another/react-ui",
  "version": "0.28.11",
  "description": "React components and hooks over the diagram editor \u2014 DiagramCanvas, Toolbar, Palette, PropertyPanel.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oh-just-another/history": "workspace:*",
    "@oh-just-another/math": "workspace:*",
    "@oh-just-another/renderer-canvas": "workspace:*",
    "@oh-just-another/renderer-core": "workspace:*",
    "@oh-just-another/renderer-svg": "workspace:*",
    "@oh-just-another/scene": "workspace:*",
    "@oh-just-another/state": "workspace:*",
    "@oh-just-another/templates": "workspace:*",
    "@oh-just-another/types": "workspace:*",
    "@oh-just-another/versioning": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "axe-core": "^4.11.4",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}